<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="NoActionBar" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary</item>
        <item name="colorAccent">@color/primary</item>
    </style>

    <style name="EntranceDialog" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowEnterAnimation">@anim/slide_in_right</item>
        <item name="android:windowExitAnimation">@anim/slide_out_right</item>
    </style>

    <style name="EdittextPrimary" parent="android:Widget.EditText">
        <item name="android:textColorHint">@color/grey_dark</item>
        <item name="android:textSize">@dimen/_8sdp</item>
        <item name="fontFamily">@font/pjs_regular</item>
        <item name="android:background">@drawable/bg_rounded_white</item>
        <item name="android:padding">@dimen/_7sdp</item>
    </style>

</resources>